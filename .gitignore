# Python cache
__pycache__/
*.py[cod]

# Runtime results and logs
results/generated/*
!results/generated/.gitkeep
results/logs/*
!results/logs/.gitkeep

# Datasets
# Benchmark CSV/JSON files are small enough to track.
!datasets/
!datasets/benchmarks/
!datasets/benchmarks/.gitkeep
!datasets/benchmarks/*.csv
!datasets/benchmarks/*.json

# Large reference image datasets stay local.
datasets/reference/*
!datasets/reference/.gitkeep

# Method checkpoints and model weights
checkpoints/*
!checkpoints/README.md
!checkpoints/**/README.md
!checkpoints/*/
checkpoints/*/*
!checkpoints/*/.gitkeep
!checkpoints/*/*/
checkpoints/*/*/*
!checkpoints/*/*/.gitkeep

# Evaluator checkpoints: keep directory layout, ignore weights
evaluators/checkpoints/*
!evaluators/checkpoints/.gitkeep
!evaluators/checkpoints/q16/
evaluators/checkpoints/q16/*
!evaluators/checkpoints/q16/.gitkeep
!evaluators/checkpoints/nudenet/
evaluators/checkpoints/nudenet/*
!evaluators/checkpoints/nudenet/.gitkeep

# Paper artifacts are curated and can be committed
!paper/
!paper/README.md
!paper/tables/
!paper/tables/.gitkeep
!paper/tables/*.csv
!paper/figures/
!paper/figures/.gitkeep
!paper/figures/*.pdf
!paper/figures/*.png

references/
.agents/

# Migrated pipeline dependency artifacts / local weights
pipelines/**/__pycache__/
pipelines/**/*.pt
pipelines/**/*.pth
pipelines/**/*.ckpt
pipelines/**/*.safetensors
pipelines/**/*.bin
pipelines/**/*.npy
pipelines/**/*.npz
pipelines/**/*.log
pipelines/**/events.out.tfevents*
pipelines/**/*.ipynb
pipelines/SG_rely/tamingtransformers/assets/*
pipelines/SG_rely/tamingtransformers/data/*
datasets/benchmarks/FPGI.csv
datasets/benchmarks/FPGI++.csv
